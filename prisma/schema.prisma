generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserType {
  customer
  provider
  admin
  both
}

enum BookingStatus {
  pending
  accepted
  completed
  cancelled
}

enum PaymentMethod {
  cash
  mobile_money
  card
  bank_transfer
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum CommissionStatus {
  owed
  paid
}

enum FeaturedPaymentStatus {
  pending
  completed
}

enum FeaturedRequestStatus {
  pending
  approved
  rejected
  expired
}

enum PayoutStatus {
  pending
  released
  failed
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum PartnerStatus {
  active
  paused
  terminated
}

enum TransactionType {
  topup
  charge
  refund
}

enum TransactionStatus {
  pending
  completed
  failed
}

model User {
  id        Int      @id @default(autoincrement()) @map("user_id")
  fullName  String   @map("full_name") @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  password  String   @db.VarChar(255)
  userType  UserType @map("user_type")
  createdAt DateTime @default(now()) @map("created_at")

  provider         ServiceProvider?
  bookings         Booking[]          @relation("CustomerBookings")
  reviews          Review[]
  sentMessages     Message[]          @relation("SentMessages")
  receivedMessages Message[]          @relation("ReceivedMessages")
  notifications    Notification[]
  feedback         PlatformFeedback[]

  @@map("users")
}

model ServiceProvider {
  id              Int      @id @default(autoincrement()) @map("provider_id")
  userId          Int      @unique @map("user_id")
  serviceCategory String   @map("service_category") @db.VarChar(100)
  experienceYears Int      @default(0) @map("experience_years")
  bio             String?  @db.Text
  rating          Decimal  @default(0.00) @db.Decimal(3, 2)
  availability    String?  @db.VarChar(100)
  isVerified      Boolean  @default(false) @map("is_verified")
  isFeatured      Boolean  @default(false) @map("is_featured")
  joinedAt        DateTime @default(now()) @map("joined_at")
  avgResponse     String   @default("Not set") @map("avg_response") @db.VarChar(50)
  languages       String   @default("English") @db.VarChar(255)
  isAvailable     Boolean  @default(true) @map("is_available")
  dailyBookingCap Int      @default(0) @map("daily_booking_cap")

  user                 User                  @relation(fields: [userId], references: [id])
  services             Service[]
  bookings             Booking[]             @relation("ProviderBookings")
  reviews              Review[]
  commissions          ProviderCommission[]
  payouts              ProviderPayout[]
  verificationRequests VerificationRequest[]
  featuredRequests     FeaturedRequest[]

  @@map("service_providers")
}

model Service {
  id          Int      @id @default(autoincrement()) @map("service_id")
  providerId  Int      @map("provider_id")
  serviceName String   @map("service_name") @db.VarChar(150)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  duration    Int?     @db.Int
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  provider ServiceProvider @relation(fields: [providerId], references: [id])
  bookings Booking[]

  @@map("services")
}

model Booking {
  id          Int           @id @default(autoincrement()) @map("booking_id")
  userId      Int           @map("user_id")
  providerId  Int           @map("provider_id")
  serviceId   Int           @map("service_id")
  bookingDate DateTime      @map("booking_date")
  address     String?       @db.VarChar(255)
  notes       String?       @db.Text
  status      BookingStatus @default(pending)
  createdAt   DateTime      @default(now()) @map("created_at")

  user       User            @relation("CustomerBookings", fields: [userId], references: [id])
  provider   ServiceProvider @relation("ProviderBookings", fields: [providerId], references: [id])
  service    Service         @relation(fields: [serviceId], references: [id])
  payment    Payment?
  reviews    Review[]
  messages   Message[]
  commission ProviderCommission?
  payout     ProviderPayout?

  @@map("bookings")
}

model Payment {
  id            Int           @id @default(autoincrement()) @map("payment_id")
  bookingId     Int           @unique @map("booking_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  paymentDate   DateTime      @default(now()) @map("payment_date")
  mobileNetwork String?       @map("mobile_network") @db.VarChar(50)
  mobilePhone   String?       @map("mobile_phone") @db.VarChar(20)
  transactionId String?       @map("transaction_id") @db.VarChar(100)

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Review {
  id         Int      @id @default(autoincrement()) @map("review_id")
  bookingId  Int      @map("booking_id")
  userId     Int      @map("user_id")
  providerId Int      @map("provider_id")
  rating     Int?
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  booking  Booking         @relation(fields: [bookingId], references: [id])
  user     User            @relation(fields: [userId], references: [id])
  provider ServiceProvider @relation(fields: [providerId], references: [id])

  @@map("reviews")
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  receiverId Int      @map("receiver_id")
  bookingId  Int?     @map("booking_id")
  message    String   @db.Text
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  sender   User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])

  @@map("messages")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  message   String   @db.Text
  link      String?  @db.VarChar(255)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model HomepageCategory {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  icon         String   @db.VarChar(10)
  description  String   @db.VarChar(255)
  filterKey    String   @map("filter_key") @db.VarChar(50)
  displayOrder Int      @default(0) @map("display_order")
  isVisible    Boolean  @default(true) @map("is_visible")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("homepage_categories")
}

model FeaturedRequest {
  id            Int                   @id @default(autoincrement())
  providerId    Int                   @map("provider_id")
  durationDays  Int                   @default(30) @map("duration_days")
  fee           Decimal               @db.Decimal(10, 2)
  paymentStatus FeaturedPaymentStatus @default(pending) @map("payment_status")
  paymentMethod String?               @map("payment_method") @db.VarChar(50)
  requestStatus FeaturedRequestStatus @default(pending) @map("request_status")
  createdAt     DateTime              @default(now()) @map("created_at")
  approvedAt    DateTime?             @map("approved_at")
  expiresAt     DateTime?             @map("expires_at")

  provider ServiceProvider @relation(fields: [providerId], references: [id])

  @@map("featured_requests")
}

model ProviderCommission {
  id            Int              @id @default(autoincrement())
  bookingId     Int              @unique @map("booking_id")
  providerId    Int              @map("provider_id")
  amount        Decimal          @db.Decimal(10, 2)
  status            CommissionStatus @default(owed)
  paymentMethod     String?          @map("payment_method") @db.VarChar(50)
  paymentReference  String?          @map("payment_reference") @db.VarChar(100)
  paidAt            DateTime?        @map("paid_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  booking  Booking         @relation(fields: [bookingId], references: [id])
  provider ServiceProvider @relation(fields: [providerId], references: [id])

  @@map("provider_commissions")
}

model ProviderPayout {
  id               Int          @id @default(autoincrement())
  bookingId        Int          @unique @map("booking_id")
  providerId       Int          @map("provider_id")
  grossAmount      Decimal      @map("gross_amount") @db.Decimal(10, 2)
  commissionAmount Decimal      @map("commission_amount") @db.Decimal(10, 2)
  taxAmount        Decimal      @map("tax_amount") @db.Decimal(10, 2)
  payoutAmount     Decimal      @map("payout_amount") @db.Decimal(10, 2)
  paymentMethod    String       @map("payment_method") @db.VarChar(50)
  payoutMethod     String       @default("platform") @map("payout_method") @db.VarChar(50)
  payoutReference  String?      @map("payout_reference") @db.VarChar(100)
  status           PayoutStatus @default(released)
  releasedAt       DateTime?    @map("released_at")
  createdAt        DateTime     @default(now()) @map("created_at")

  booking  Booking         @relation(fields: [bookingId], references: [id])
  provider ServiceProvider @relation(fields: [providerId], references: [id])

  @@map("provider_payouts")
}

model VerificationRequest {
  id               Int                @id @default(autoincrement())
  providerId       Int                @map("provider_id")
  idType           String             @map("id_type") @db.VarChar(50)
  idNumber         String             @map("id_number") @db.VarChar(100)
  documentPath     String?            @map("document_path") @db.VarChar(255)
  certPath         String?            @map("cert_path") @db.VarChar(255)
  notes            String?            @db.Text
  status           VerificationStatus @default(pending)
  adminNotes       String?            @map("admin_notes") @db.Text
  smileidStatus    String             @default("pending") @map("smileid_status") @db.VarChar(20)
  smileidSummary   String?            @map("smileid_summary") @db.VarChar(255)
  smileidReference String?            @map("smileid_reference") @db.VarChar(100)
  smileidResponse  String?            @map("smileid_response") @db.Text
  smileidCheckedAt DateTime?          @map("smileid_checked_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  reviewedAt       DateTime?          @map("reviewed_at")

  provider ServiceProvider @relation(fields: [providerId], references: [id])

  @@map("verification_requests")
}

model PlatformFeedback {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  rating     Int
  category   String   @default("general") @db.VarChar(50)
  message    String   @db.Text
  adminReply String?  @map("admin_reply") @db.Text
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("platform_feedback")
}

model Partner {
  id           Int           @id @default(autoincrement())
  slug         String        @unique @db.VarChar(50)
  name         String        @db.VarChar(100)
  category     String        @db.VarChar(50)
  description  String?       @db.Text
  contactEmail String?       @map("contact_email") @db.VarChar(120)
  contactUrl   String?       @map("contact_url") @db.VarChar(255)
  status       PartnerStatus @default(active)
  startedAt    DateTime?     @map("started_at") @db.Date
  notes        String?       @db.Text
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  configs      PartnerConfig[]
  wallet       PartnerWallet?
  activityLogs PartnerActivityLog[]
  transactions PartnerTransaction[]

  @@map("partners")
}

model PartnerConfig {
  id          Int      @id @default(autoincrement())
  partnerId   Int      @map("partner_id")
  configKey   String   @map("config_key") @db.VarChar(50)
  configValue String?  @map("config_value") @db.Text
  isSecret    Boolean  @default(false) @map("is_secret")
  updatedAt   DateTime @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, configKey], name: "unq_partner_key")
  @@map("partner_config")
}

model PartnerWallet {
  id                  Int      @id @default(autoincrement())
  partnerId           Int      @unique @map("partner_id")
  balance             Decimal  @default(0.00) @db.Decimal(12, 2)
  currency            String   @default("GHS") @db.VarChar(3)
  costPerCheck        Decimal  @default(3.50) @map("cost_per_check") @db.Decimal(8, 2)
  lowBalanceThreshold Decimal  @default(50.00) @map("low_balance_threshold") @db.Decimal(10, 2)
  updatedAt           DateTime @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_wallet")
}

model PartnerActivityLog {
  id        Int      @id @default(autoincrement())
  partnerId Int      @map("partner_id")
  action    String   @db.VarChar(50)
  status    String   @db.VarChar(20)
  summary   String?  @db.VarChar(255)
  reference String?  @db.VarChar(100)
  meta      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_activity_log")
}

model PartnerTransaction {
  id            Int               @id @default(autoincrement())
  partnerId     Int               @map("partner_id")
  type          TransactionType
  amount        Decimal           @db.Decimal(12, 2)
  balanceAfter  Decimal           @map("balance_after") @db.Decimal(12, 2)
  reference     String?           @db.VarChar(100)
  paymentMethod String?           @map("payment_method") @db.VarChar(50)
  description   String?           @db.VarChar(255)
  status        TransactionStatus @default(completed)
  createdAt     DateTime          @default(now()) @map("created_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_transactions")
}
